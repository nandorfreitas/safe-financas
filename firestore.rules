rules_version = '2';

// Regras Fase 1.
// Princípio: é MEMBRO do workspace E (entidade compartilhada OU é o dono).
// Para transações, a visibilidade/dono são DENORMALIZADOS (_visibilidade, _donoUid)
// para não precisar de get() na conta/cartão-pai a cada leitura.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function wsData(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)).data;
    }

    function isMember(wsId) {
      return isSignedIn() && request.auth.uid in wsData(wsId).memberUids;
    }

    // Visível se a entidade é compartilhada OU o usuário é o dono.
    function canSeeEntity(data) {
      return data.visibilidade == 'compartilhada' || data.donoUid == request.auth.uid;
    }

    match /workspaces/{wsId} {
      // Só membros leem; criação exige que o criador seja o owner e membro.
      allow read: if isMember(wsId);
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;
      // Atualização/remoção: membros (convite de membro é feito por Cloud Function
      // com privilégio de admin; o owner pode ajustar limiar etc.).
      allow update: if isMember(wsId);
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;

      // ── Contas e investimentos (entidade-raiz, carrega visibilidade) ──
      match /accounts/{accId} {
        allow read: if isMember(wsId) && canSeeEntity(resource.data);
        allow create: if isMember(wsId)
          && request.resource.data.donoUid == request.auth.uid;
        allow update, delete: if isMember(wsId) && canSeeEntity(resource.data);
      }

      // ── Cartões (entidade-raiz) ──
      match /cards/{cardId} {
        allow read: if isMember(wsId) && canSeeEntity(resource.data);
        allow create: if isMember(wsId)
          && request.resource.data.donoUid == request.auth.uid;
        allow update, delete: if isMember(wsId) && canSeeEntity(resource.data);

        // Faturas herdam a visibilidade do cartão-pai (get() no cartão).
        match /invoices/{invId} {
          function card() {
            return get(/databases/$(database)/documents/workspaces/$(wsId)/cards/$(cardId)).data;
          }
          allow read, write: if isMember(wsId) && canSeeEntity(card());
        }
      }

      // ── Categorias: nível de workspace, sem visibilidade por entidade ──
      match /categories/{catId} {
        allow read, write: if isMember(wsId);
      }

      // ── Transações: visibilidade DENORMALIZADA (_visibilidade/_donoUid) ──
      match /transactions/{txId} {
        function canSeeTx(data) {
          return data._visibilidade == 'compartilhada' || data._donoUid == request.auth.uid;
        }
        allow read: if isMember(wsId) && canSeeTx(resource.data);
        allow create: if isMember(wsId)
          && request.resource.data.criadoPor == request.auth.uid
          && canSeeTx(request.resource.data);
        allow update, delete: if isMember(wsId) && canSeeTx(resource.data);
      }

      // ── Fechamentos de mês: nível de workspace ──
      match /monthlyReviews/{competencia} {
        allow read, write: if isMember(wsId);
      }
    }
  }
}
