# Credenciais do app web do Firebase (Console > Configurações do projeto > Seus apps > Web).
# Copie para `.env.local` e preencha. Estas chaves são públicas por design (protegidas
# pelas Security Rules), mas mantemos `.env.local` fora do git por higiene.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# "true" para usar os emuladores locais (Auth/Firestore/Functions) em vez da nuvem.
VITE_USE_EMULATORS=false
